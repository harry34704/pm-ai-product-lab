{
  "name": "mockroom-ai",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "node scripts/ensure-env.mjs && concurrently -k -n web,desktop \"npm run dev --workspace @mockroom/web\" \"npm run dev --workspace @mockroom/desktop\"",
    "build": "node scripts/ensure-env.mjs && npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "db:start": "docker compose -f docker-compose.postgres.yml up -d",
    "db:stop": "docker compose -f docker-compose.postgres.yml down -v",
    "prisma:migrate": "node scripts/ensure-env.mjs && prisma migrate deploy",
    "prisma:deploy": "node scripts/ensure-env.mjs && prisma migrate deploy",
    "prisma:dev": "node scripts/ensure-env.mjs && prisma migrate dev",
    "prisma:seed": "node scripts/ensure-env.mjs && tsx prisma/seed.ts",
    "electron:build": "node scripts/ensure-env.mjs && npm run build --workspace @mockroom/shared && npm run build --workspace @mockroom/web && npm run package --workspace @mockroom/desktop",
    "vercel:build": "pnpm --filter @mockroom/shared build && pnpm --filter @mockroom/web vercel-build",
    "vercel:check": "node scripts/check-production-env.mjs",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "@mockroom/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@types/node": "^22.13.10",
    "concurrently": "^9.1.2",
    "electron-builder": "^25.1.8",
    "playwright": "^1.51.0",
    "prisma": "^6.4.1",
    "tsx": "^4.19.3",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
