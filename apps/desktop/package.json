{
  "name": "@mockroom/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "wait-on tcp:3000 && cross-env ELECTRON_START_URL=http://localhost:3000 npm run build && electron dist/main.js",
    "build": "tsup electron/main.ts electron/preload.ts --format cjs --out-dir dist --external electron",
    "lint": "tsc --noEmit",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "electron": "^35.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "cross-env": "^7.0.3",
    "electron-builder": "^25.1.8",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "ai.mockroom.desktop",
    "productName": "MockRoom AI",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../web/.next/standalone",
        "to": "web"
      },
      {
        "from": "../web/.next/static",
        "to": "web/.next/static"
      },
      {
        "from": "../web/public",
        "to": "web/public"
      }
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
