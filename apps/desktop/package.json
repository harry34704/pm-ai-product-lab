{
  "name": "@mockroom/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "MockRoom AI desktop shell",
  "author": "MockRoom AI",
  "main": "dist/main.js",
  "scripts": {
    "dev": "wait-on tcp:3000 && cross-env ELECTRON_START_URL=http://localhost:3000 npm run build && node scripts/dev.mjs",
    "build": "tsup electron/main.ts electron/preload.ts --format cjs --out-dir dist --external electron",
    "lint": "tsc --noEmit",
    "package": "npm run build && electron-builder --publish never"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.0",
    "@types/node": "^22.13.10",
    "cross-env": "^7.0.3",
    "electron": "^35.0.1",
    "electron-builder": "^25.1.8",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "ai.mockroom.desktop",
    "productName": "MockRoom AI",
    "asar": true,
    "artifactName": "MockRoom-AI-${os}-${arch}.${ext}",
    "afterSign": "scripts/notarize.mjs",
    "files": [
      "dist/**/*",
      "package.json",
      "scripts/notarize.mjs",
      "build/**/*"
    ],
    "extraResources": [
      {
        "from": "../web/.next/standalone",
        "to": "web"
      },
      {
        "from": "../web/.next/static",
        "to": "web/.next/static"
      },
      {
        "from": "../web/public",
        "to": "web/public"
      }
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.business",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "gatekeeperAssess": false,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "MockRoom AI uses the microphone only during visible, user-initiated practice interviews."
      }
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
